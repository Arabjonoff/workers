# Bu faylni nusxalab .env nomida saqlang va haqiqiy qiymatlarni kiriting.
# .env fayl gitga qo'shilmaydi (maxfiy ma'lumot saqlanadi).

# Django
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com

# CORS — brauzerdan (masalan web-dashboard) API'ga so'rov yuboradigan domenlar
CORS_ALLOWED_ORIGINS=https://example.com

# Baza — DB_ENGINE=postgresql bo'lmasa avtomatik SQLite ishlatiladi
DB_ENGINE=postgresql
DB_NAME=workers
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
